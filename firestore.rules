rules_version = '2';

// ============================================================
// Petisi Bela Rakyat - Firestore Security Rules
// ============================================================
// IMPORTANT: The users/{uid} collection has a special read rule
// to avoid circular dependency:
//   1. A signed-in user can ALWAYS read their OWN document
//      (request.auth.uid == id) — no role lookup needed.
//   2. Reading OTHER users' documents requires admin role,
//      which calls getUserRole() — but that reads the caller's
//      OWN document (already allowed by rule #1), so no cycle.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // Reads the caller's OWN user document to get their role.
    // Safe because users/{uid} read rule allows request.auth.uid == id.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == 'super_admin';
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'super_admin' || getUserRole() == 'admin' || getUserRole() == 'editor');
    }

    // ----------------------------------------------------------
    // Public content - read published, admin write
    // ----------------------------------------------------------
    match /blog/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }
    match /news/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }
    match /campaigns/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /pengurus/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /penasehat/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /relawan/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /supporters/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /work/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /transparency/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /reports/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /settings/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /media/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /proposals/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }
    match /messages/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Debug logs — allow signed-in users to create (for login telemetry)
    match /debug_logs/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------
    // Users - role management
    // ----------------------------------------------------------
    // CRITICAL: read is split into two OR branches to avoid
    // circular dependency:
    //   - Self-read (request.auth.uid == id): NO role lookup,
    //     so getUserRole() can safely read the caller's own doc
    //     later when evaluating isAdmin() for other operations.
    //   - Admin-read (isAdmin()): allowed for reading other
    //     users' documents. isAdmin() calls getUserRole() which
    //     reads the CALLER's own doc — already permitted by the
    //     self-read branch above. No cycle.
    // ----------------------------------------------------------
    match /users/{id} {
      allow read: if isSignedIn() && (request.auth.uid == id || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == id || isSuperAdmin());
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid == id && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isSuperAdmin();
    }
  }
}
