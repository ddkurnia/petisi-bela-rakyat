# ============================================================
# Petisi Bela Rakyat - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your credentials.
# After setting these, the app runs without code changes.
#
# Setup guides:
# - Firebase: https://console.firebase.google.com/
# - Cloudinary: https://cloudinary.com/console

# ============================================================
# Firebase Client SDK (browser + Next.js server components)
# ============================================================
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# Firebase Admin SDK (server-side - API routes only)
# ============================================================
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then copy project_id, client_email, and private_key from the downloaded JSON.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# IMPORTANT: Keep the quotes around the key and preserve \n as literal \n in the env value.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXX\n-----END PRIVATE KEY-----\n"

# ============================================================
# Cloudinary (media uploads)
# ============================================================
# Get these from: Cloudinary Console → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: only needed if using client-side unsigned uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=belarakyat_unsigned

# ============================================================
# Site Configuration
# ============================================================
NEXT_PUBLIC_SITE_URL=https://belarakyat.org
